<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap estático para las páginas públicas y fijas.
  Las páginas dinámicas (/user/:id) deberían servirse desde tu backend
  con un endpoint tipo /sitemap-users.xml generado desde la base de datos
  (ver ejemplo en la respuesta del chat).
-->
<urlset xmlns="https://www.sitemaps.org/schemas/sitemap/0.9">
